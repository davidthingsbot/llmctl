#!/usr/bin/env bash
# llmctl — run one or more local LLM servers on this host (dual RTX 3090) and
# keep the agents (openclaw + hermes) pointed at the right one.
#
# Fresh replacement for the dual-rtx3090__*.sh switch scripts. Differences:
#   * Every model has its OWN port (convention below) — models are no longer
#     mutually exclusive by port, so several can run at once IF they fit in VRAM.
#   * Generates its own systemd user units (llm-<name>.service) and run scripts
#     (~/.config/llmctl/run-<name>.sh). The legacy qwen-dual3090-* /
#     local-agent-qwen units are stopped+disabled the first time you start
#     anything from here.
#   * `set` / `point` rewrite the agent configs (hermes ~/.hermes/config.yaml,
#     openclaw ~/.openclaw/*.json incl. auth-profiles) with the right base_url,
#     model id, context window and API key, then restart the gateways.
#   * `set` / `point` also manage the browser chat page: llama.cpp models serve
#     their own UI on the model port; for vLLM models the open-webui docker
#     container (http://localhost:8088) is started/repointed, and it is stopped
#     when a llama.cpp model takes over. `status` shows the current chat link.
#
# Port convention (fixed per model, agents never need to guess):
#   19434  27b-fp8        vLLM       Qwen/Qwen3.6-27B-FP8          (current default)
#   19435  35b-moe-vllm   vLLM       Qwen/Qwen3.6-35B-A3B-FP8
#   19436  27b-q8         llama.cpp  Qwen3.6-27B-Q8_0.gguf
#   19437  35b-moe-gguf   llama.cpp  Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf
#
# Usage:
#   llmctl                     interactive menu
#   llmctl <model>             shorthand for `llmctl set <model>`
#   llmctl list                registry + status
#   llmctl status              units, health, GPU, where the agents point
#   llmctl set  <model>        THE switch: stop everything else, start <model>,
#                              point both agents at it (permanent across boot)
#   llmctl up   <model>...     start model(s) alongside whatever is running
#   llmctl down <model>...|all stop model(s)
#   llmctl point <model>       repoint openclaw+hermes only (model must be up)
#   llmctl env  <model>        print OPENAI_* exports for shell/manual clients
#   llmctl logs <model> [-f]   journal for a model's unit
#   llmctl add                 interactive wizard: register a NEW model
#   llmctl remove <model>      unregister a wizard-added model (stops it first)
#   llmctl bench <model>       benchmark a running model now (tok/s, GPU, power)
#   llmctl stats [model]       show recorded load times + benchmark history
#   llmctl machine             show the effective machine profile + probed hardware
#   llmctl machine init        probe this machine and write ~/.config/llmctl/machine.conf
#
# Machine profile: host-specific facts live in ~/.config/llmctl/machine.conf
# (key=value, optional — without it the defaults below describe THIS box).
# Keys: MACHINE_NAME, GPUS_DEFAULT, TENSOR_PARALLEL_DEFAULT, VRAM_PER_GPU_MB,
#       VLLM_BIN, VLLM_KEYFILE, LLAMA_SERVER, LLAMA_KEYFILE, WIZARD_BASE_PORT,
#       ENABLE_BUILTIN_MODELS (0 on other machines: registry comes only from
#       models.d/), LEGACY_UNITS, HERMES_ENABLE/CFG/UNIT,
#       OPENCLAW_ENABLE/DIR/UNIT, WEBUI_ENABLE/CONTAINER/PORT/IMAGE.
# To port llmctl to a new machine: copy this script + run `llmctl machine init`,
# edit the generated profile, then `llmctl add` your models.
#
# Every start is timed and (by default) followed by a small benchmark; results
# append to ~/.config/llmctl/stats.jsonl and feed the "typical load time"
# estimate shown on the next start. STATS=0 llmctl set <m> skips the benchmark.
#
# Wizard-added models live in ~/.config/llmctl/models.d/<name>.conf (key=value,
# editable by hand; see `llmctl add` output). Built-in models live in the
# registry block below.
#
# NOTE: all four current configs want ~21-23 GB per card, so no two of them fit
# together on 2x24 GB. `up` checks free VRAM first (FORCE=1 to override).
# Concurrency becomes useful once you add smaller configs to the registry.

set -euo pipefail

# ----------------------------------------------------------------------------
# Registry — add a model: append its name and fill in every map + a cmd_* case
# ----------------------------------------------------------------------------
MODELS=(27b-fp8 35b-moe-vllm 27b-q8 35b-moe-gguf)

declare -A PORT=(    [27b-fp8]=19434 [35b-moe-vllm]=19435 [27b-q8]=19436 [35b-moe-gguf]=19437 )
declare -A BACKEND=( [27b-fp8]=vllm  [35b-moe-vllm]=vllm  [27b-q8]=llamacpp [35b-moe-gguf]=llamacpp )
# id = served model name (what agents put in "model")
declare -A ID=(      [27b-fp8]=qwen3.6-27b-fp8 [35b-moe-vllm]=qwen3.6-35b-a3b-fp8
                     [27b-q8]=qwen3.6-27b-q8   [35b-moe-gguf]=qwen3.6-35b-a3b-q4 )
# context window written into the agent configs (safe round numbers <= server max)
declare -A CTX=(     [27b-fp8]=128000 [35b-moe-vllm]=128000 [27b-q8]=256000 [35b-moe-gguf]=256000 )
declare -A DESC=(    [27b-fp8]="Qwen3.6-27B dense FP8, vLLM, 128K, tuned"
                     [35b-moe-vllm]="Qwen3.6-35B-A3B MoE FP8, vLLM, 128K"
                     [27b-q8]="Qwen3.6-27B dense Q8_0 GGUF, llama.cpp, 2x256K"
                     [35b-moe-gguf]="Qwen3.6-35B-A3B MoE Q4 GGUF, llama.cpp, 2x256K" )
# MiB of free VRAM needed PER GPU before start (estimates from past runs)
declare -A VRAM=(    [27b-fp8]=23200 [35b-moe-vllm]=22700 [27b-q8]=23000 [35b-moe-gguf]=21500 )
# seconds to wait for /health
declare -A TIMEOUT=( [27b-fp8]=900 [35b-moe-vllm]=900 [27b-q8]=240 [35b-moe-gguf]=240 )

VLLM_BIN="$HOME/.venvs/vllm/bin/vllm"
VLLM_KEYFILE="$HOME/.config/vllm/api-keys"
LLAMA_SERVER="${LLAMA_SERVER:-$HOME/work/llama.cpp/build/bin/llama-server}"
LLAMA_KEYFILE="$HOME/.config/llama.cpp/api-keys"
declare -A KEYFILE=( [27b-fp8]=$VLLM_KEYFILE [35b-moe-vllm]=$VLLM_KEYFILE
                     [27b-q8]=$LLAMA_KEYFILE [35b-moe-gguf]=$LLAMA_KEYFILE )

MODELS_DIR="$HOME/models"   # where GGUF weights live (profile-overridable);
                            # llmctl itself can be installed/run from anywhere
# GGUF_27B / GGUF_35B are derived from MODELS_DIR after the profile loads

RUN_DIR="$HOME/.config/llmctl"
STATS_FILE="${STATS_FILE:-$RUN_DIR/stats.jsonl}"   # one JSON record per start/bench
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"

# Old single-port (19434) units this script supersedes
LEGACY_UNITS=(
  qwen-dual3090-27b-q8-llamacpp.service
  qwen-dual3090-35b-moe-llamacpp.service
  qwen-dual3090-27b-fp8-vllm.service
  qwen-dual3090-35b-moe-vllm.service
  local-agent-qwen.service
)

# Browser chat: llama.cpp serves its own UI on the model port; vLLM has none,
# so the open-webui docker container (port 8088) fronts it. `set`/`point` keep
# it running+pointed for vLLM models and stop it for llama.cpp ones.
WEBUI_CONTAINER="open-webui"
WEBUI_PORT=8088
WEBUI_IMAGE="ghcr.io/open-webui/open-webui:main"

HERMES_CFG="$HOME/.hermes/config.yaml"
HERMES_CTX_CACHE="$HOME/.hermes/context_length_cache.yaml"
HERMES_UNIT="hermes-gateway.service"
OPENCLAW_DIR="$HOME/.openclaw"
OPENCLAW_UNIT="openclaw-gateway.service"

# Machine-profile defaults (overridable via ~/.config/llmctl/machine.conf).
# These describe the original host: DW-ASUS-LINUX, dual RTX 3090.
MACHINE_CONF="${MACHINE_CONF:-$RUN_DIR/machine.conf}"
MACHINE_NAME="$(hostname 2>/dev/null || echo unknown)"
ACCEL=""                       # cuda | rocm | cpu; empty = auto-detect
GPUS_DEFAULT="0,1"             # default visible devices for new models ("" on cpu)
TENSOR_PARALLEL_DEFAULT=""     # empty = derive from GPUS_DEFAULT
VRAM_PER_GPU_MB=24576          # informational / sanity checks (0 on cpu)
WIZARD_BASE_PORT=19438         # `llmctl add` picks the next free port from here
ENABLE_BUILTIN_MODELS=1        # 0 = ignore the registry block (models.d/ only)
HERMES_ENABLE=1
OPENCLAW_ENABLE=1
WEBUI_ENABLE=1

# ----------------------------------------------------------------------------
# Helpers
# ----------------------------------------------------------------------------
log() { printf '\033[1;36m[llmctl]\033[0m %s\n' "$*"; }
err() { printf '\033[1;31m[llmctl:error]\033[0m %s\n' "$*" >&2; }
die() { err "$*"; exit 1; }

unit_of()  { echo "llm-$1.service"; }
url_of()   { echo "http://127.0.0.1:${PORT[$1]}/v1"; }
key_of()   { cat "${KEYFILE[$1]}"; }

# ----------------------------------------------------------------------------
# External models (~/.config/llmctl/models.d/*.conf) — added by `llmctl add`.
# Files are PARSED (key=value), not sourced, so a broken file can't break llmctl.
# Required keys: BACKEND (vllm|llamacpp), PORT, MODEL_REF (HF repo | gguf path).
# Optional: MODEL_ID, CTX, DESC, VRAM_MB, HEALTH_TIMEOUT, GPUS, EXTRA_ARGS,
#           TENSOR_PARALLEL, GPU_UTIL, MAX_MODEL_LEN (vllm),
#           SERVER_CTX, STREAMS (llamacpp).
# ----------------------------------------------------------------------------
MODELS_D="$HOME/.config/llmctl/models.d"
declare -A EXTERNAL MREF TP GUTIL MAXLEN SRVCTX STREAMS GPUS XARGS

conf_get() { # conf_get <key> <file> [default]
  local v
  v="$(sed -n "s/^$1=//p" "$2" | tail -1)"
  v="${v%\"}"; v="${v#\"}"
  echo "${v:-${3:-}}"
}

load_machine_profile() {
  [[ -f "$MACHINE_CONF" ]] || return 0
  local k v n
  for k in MACHINE_NAME GPUS_DEFAULT TENSOR_PARALLEL_DEFAULT VRAM_PER_GPU_MB \
           VLLM_BIN VLLM_KEYFILE LLAMA_SERVER LLAMA_KEYFILE MODELS_DIR \
           WIZARD_BASE_PORT ENABLE_BUILTIN_MODELS \
           HERMES_ENABLE HERMES_CFG HERMES_UNIT \
           OPENCLAW_ENABLE OPENCLAW_DIR OPENCLAW_UNIT \
           WEBUI_ENABLE WEBUI_CONTAINER WEBUI_PORT WEBUI_IMAGE; do
    v="$(conf_get "$k" "$MACHINE_CONF")"
    [[ -n "$v" ]] && printf -v "$k" '%s' "$v"
  done
  v="$(conf_get ACCEL "$MACHINE_CONF")"
  [[ -n "$v" ]] && ACCEL="$v"
  v="$(conf_get LEGACY_UNITS "$MACHINE_CONF")"
  [[ -n "$v" ]] && read -ra LEGACY_UNITS <<< "$v"

  if [[ "$ENABLE_BUILTIN_MODELS" != 1 ]]; then
    for n in "${MODELS[@]}"; do
      unset "PORT[$n]" "BACKEND[$n]" "ID[$n]" "CTX[$n]" "DESC[$n]" \
            "VRAM[$n]" "TIMEOUT[$n]" "KEYFILE[$n]"
    done
    MODELS=()
  else
    # keyfile paths may have been overridden — refresh the built-ins' entries
    for n in "${MODELS[@]}"; do
      [[ "${BACKEND[$n]}" == vllm ]] && KEYFILE[$n]="$VLLM_KEYFILE" || KEYFILE[$n]="$LLAMA_KEYFILE"
    done
  fi
}
load_machine_profile

# Resolve the accelerator: never assume CUDA. Auto-detect when unset, and pick
# the matching visible-devices env var for generated run scripts.
if [[ -z "$ACCEL" ]]; then
  if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi -L >/dev/null 2>&1; then
    ACCEL=cuda
  elif command -v rocm-smi >/dev/null 2>&1; then
    ACCEL=rocm
  else
    ACCEL=cpu
  fi
fi
case "$ACCEL" in
  cuda) GPU_ENV_VAR="CUDA_VISIBLE_DEVICES";;
  rocm) GPU_ENV_VAR="HIP_VISIBLE_DEVICES";;
  *)    GPU_ENV_VAR=""; GPUS_DEFAULT=""; VRAM_PER_GPU_MB=0;;
esac

GGUF_27B="$MODELS_DIR/gguf/qwen3.6/Qwen3.6-27B-GGUF/Qwen3.6-27B-Q8_0.gguf"
GGUF_35B="$MODELS_DIR/gguf/qwen3.6/Qwen3.6-35B-A3B-GGUF/Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf"

load_external_models() {
  local f name backend port
  shopt -s nullglob
  for f in "$MODELS_D"/*.conf; do
    name="$(basename "$f" .conf)"
    if [[ -n "${PORT[$name]:-}" ]]; then
      err "models.d: '$name' collides with an existing model — skipping $f"; continue
    fi
    backend="$(conf_get BACKEND "$f")"
    port="$(conf_get PORT "$f")"
    if [[ ! "$backend" =~ ^(vllm|llamacpp)$ || ! "$port" =~ ^[0-9]+$ || -z "$(conf_get MODEL_REF "$f")" ]]; then
      err "models.d: $f needs BACKEND=vllm|llamacpp, numeric PORT, MODEL_REF — skipping"; continue
    fi
    local n
    for n in "${MODELS[@]}"; do
      [[ "${PORT[$n]}" == "$port" ]] && { err "models.d: $f wants port $port, already used by '$n' — skipping"; continue 2; }
    done
    MODELS+=("$name")
    EXTERNAL[$name]="$f"
    BACKEND[$name]="$backend"
    PORT[$name]="$port"
    MREF[$name]="$(conf_get MODEL_REF "$f")"
    ID[$name]="$(conf_get MODEL_ID "$f" "$name")"
    CTX[$name]="$(conf_get CTX "$f" 128000)"
    DESC[$name]="$(conf_get DESC "$f" "${MREF[$name]} ($backend)")"
    VRAM[$name]="$(conf_get VRAM_MB "$f" 20000)"
    GPUS[$name]="$(conf_get GPUS "$f" "$GPUS_DEFAULT")"
    XARGS[$name]="$(conf_get EXTRA_ARGS "$f")"
    if [[ "$backend" == vllm ]]; then
      KEYFILE[$name]="$VLLM_KEYFILE"
      TIMEOUT[$name]="$(conf_get HEALTH_TIMEOUT "$f" 900)"
      TP[$name]="$(conf_get TENSOR_PARALLEL "$f" 2)"
      GUTIL[$name]="$(conf_get GPU_UTIL "$f" 0.90)"
      MAXLEN[$name]="$(conf_get MAX_MODEL_LEN "$f" "${CTX[$name]}")"
    else
      KEYFILE[$name]="$LLAMA_KEYFILE"
      TIMEOUT[$name]="$(conf_get HEALTH_TIMEOUT "$f" 300)"
      SRVCTX[$name]="$(conf_get SERVER_CTX "$f" "${CTX[$name]}")"
      STREAMS[$name]="$(conf_get STREAMS "$f" 1)"
    fi
  done
}
load_external_models

require_model() {
  [[ -n "${PORT[$1]:-}" ]] || die "unknown model '$1' (know: ${MODELS[*]})"
}

is_active() { systemctl --user is-active --quiet "$(unit_of "$1")" 2>/dev/null; }

is_healthy() {
  curl -fsS -o /dev/null --max-time 2 "http://127.0.0.1:${PORT[$1]}/health" 2>/dev/null
}

wait_health_timed() { # wait_health_timed <name> <timeout> [est] — stdout: elapsed seconds
  local name="$1" timeout="$2" est="${3:-}" i
  for ((i=0; i<timeout; i++)); do
    is_healthy "$name" && { echo "$i"; return 0; }
    if (( i > 0 && i % 10 == 0 )); then
      printf '\033[1;36m[llmctl]\033[0m   … loading: %ss elapsed%s\n' \
        "$i" "${est:+ (typical ~${est}s)}" >&2
    fi
    sleep 1
  done
  return 1
}

est_load() { # est_load <name> — avg of last 5 recorded load times, empty if none
  [[ -f "$STATS_FILE" ]] || return 1
  local v
  v="$(jq -rs --arg m "$1" \
    '[.[] | select(.model==$m and .load_s!=null) | .load_s]
     | if length==0 then empty else (.[-5:] | add/length | round) end' \
    "$STATS_FILE" 2>/dev/null)"
  [[ -n "$v" ]] && echo "$v"
}

bench_and_log() { # bench_and_log <name> [load_seconds]
  # 1 warmup, then 1 streamed generation over a ~1.5K-token prompt:
  #   time-to-first-token          -> prompt processing (prefill) tok/s
  #   token cadence after 1st tok  -> generation tok/s
  # GPU sampled in both phases; record appended to STATS_FILE.
  local name="$1" load="${2:-}"
  mkdir -p "$RUN_DIR"
  B_URL="$(url_of "$name")" B_KEY="$(key_of "$name")" B_ID="${ID[$name]}" \
  B_NAME="$name" B_LOAD="$load" B_STATS="$STATS_FILE" python3 <<'PYEOF'
import json, os, subprocess, threading, time, urllib.request

url, key, mid = os.environ["B_URL"], os.environ["B_KEY"], os.environ["B_ID"]
HDRS = {"Content-Type": "application/json", "Authorization": "Bearer " + key}

def req(body):
    return urllib.request.Request(url + "/chat/completions",
                                  data=json.dumps(body).encode(), headers=HDRS)

# warmup absorbs one-time compile/graph costs; salted so it can't seed the
# prefix cache for the measured prompt below
salt = str(time.time_ns())
with urllib.request.urlopen(req({
    "model": mid, "max_tokens": 8, "temperature": 0,
    "messages": [{"role": "user", "content": "warmup " + salt}]}), timeout=300) as r:
    r.read()

prompt = (f"[bench {salt}] Ignore the repetition and reply with one sentence: "
          + "The quick brown fox jumps over the lazy dog. " * 150)

gpu = []
first_token = threading.Event()
def sample(phase, delay):
    time.sleep(delay)
    try:
        out = subprocess.run(
            ["nvidia-smi", "--query-gpu=index,utilization.gpu,memory.used,power.draw",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5).stdout
        for line in out.strip().splitlines():
            i, u, m, p = [x.strip() for x in line.split(",")]
            gpu.append({"phase": phase, "gpu": int(i), "util_pct": float(u),
                        "mem_mib": float(m), "power_w": float(p)})
    except Exception:
        pass
def sample_gen():
    if first_token.wait(timeout=280):
        sample("gen", 0.25)

th_pre = threading.Thread(target=sample, args=("prefill", 0.15)); th_pre.start()
th_gen = threading.Thread(target=sample_gen); th_gen.start()

t0 = time.monotonic(); t_first = None; usage = None; chunks = 0
with urllib.request.urlopen(req({
    "model": mid, "max_tokens": 200, "temperature": 0, "stream": True,
    "stream_options": {"include_usage": True},
    "messages": [{"role": "user", "content": prompt}]}), timeout=300) as r:
    for raw in r:
        line = raw.decode("utf-8", "replace").strip()
        if not line.startswith("data:"):
            continue
        data = line[5:].strip()
        if data == "[DONE]":
            break
        try:
            ev = json.loads(data)
        except ValueError:
            continue
        if ev.get("usage"):
            usage = ev["usage"]
        ch = ev.get("choices") or []
        if ch:
            d = ch[0].get("delta") or {}
            if d.get("content") or d.get("reasoning") or d.get("reasoning_content"):
                if t_first is None:
                    t_first = time.monotonic()
                    first_token.set()
                chunks += 1
t_end = time.monotonic()
first_token.set()  # release the gen sampler even if nothing streamed
th_pre.join(); th_gen.join()

pt = (usage or {}).get("prompt_tokens")
ct = (usage or {}).get("completion_tokens") or chunks or None
ttft = round(t_first - t0, 3) if t_first else None
prompt_tps = round(pt / ttft, 1) if pt and ttft else None
gen_tps = (round((ct - 1) / (t_end - t_first), 1)
           if ct and ct > 1 and t_first and t_end > t_first else None)
tok_s = round(ct / (t_end - t0), 1) if ct else None

rec = {
    "ts": time.strftime("%Y-%m-%dT%H:%M:%S"),
    "model": os.environ["B_NAME"],
    "load_s": float(os.environ["B_LOAD"]) if os.environ["B_LOAD"] else None,
    "ttft_s": ttft, "prompt_tokens": pt, "prompt_tps": prompt_tps,
    "gen_tps": gen_tps, "tok_s": tok_s,
    "bench_tokens": ct, "bench_time_s": round(t_end - t0, 2),
    "gpu": gpu,
}
with open(os.environ["B_STATS"], "a") as f:
    f.write(json.dumps(rec) + "\n")

g = " | ".join(f"GPU{s['gpu']}: {s['util_pct']:.0f}% {s['power_w']:.0f}W"
               for s in gpu if s["phase"] == "gen") or "no GPU sample"
print(f"[llmctl]   benchmark: prefill {pt or '?'} tok in {ttft or '?'}s"
      f" ({prompt_tps or '?'} tok/s) | gen {ct or '?'} tok @ {gen_tps or '?'} tok/s | {g}")
PYEOF
}

start_model() { # start_model <name> — write unit, timed start, health-wait, bench+log
  local name="$1" est="" elapsed
  write_unit "$name"
  est="$(est_load "$name" || true)"
  if [[ -n "$est" ]]; then
    log "starting $name (:${PORT[$name]}) — typical load time ~${est}s, timeout ${TIMEOUT[$name]}s"
  else
    log "starting $name (:${PORT[$name]}) — no load-time history yet, timeout ${TIMEOUT[$name]}s"
  fi
  systemctl --user start "$(unit_of "$name")"
  elapsed="$(wait_health_timed "$name" "${TIMEOUT[$name]}" "$est")" || return 1
  log "READY in ${elapsed}s: ${ID[$name]} @ $(url_of "$name")"
  if [[ "${STATS:-1}" == 1 ]]; then
    bench_and_log "$name" "$elapsed" || err "benchmark failed — model is up regardless"
  fi
}

status_of() { # short status string
  if is_active "$1"; then
    is_healthy "$1" && echo "up+healthy" || echo "starting"
  else
    echo "-"
  fi
}

stop_legacy() {
  local u any=0
  for u in "${LEGACY_UNITS[@]}"; do
    if systemctl --user is-active --quiet "$u" 2>/dev/null; then
      log "stopping legacy unit $u (superseded by llmctl)"
      systemctl --user stop "$u" || true
      any=1
    fi
    systemctl --user disable "$u" 2>/dev/null || true
  done
  (( any )) && log "legacy 19434 units stopped+disabled" || true
}

ensure_linger() {
  loginctl show-user "$USER" 2>/dev/null | grep -q 'Linger=yes' && return 0
  log "enabling user lingering (boot autostart without login)"
  loginctl enable-linger "$USER" 2>/dev/null \
    || sudo loginctl enable-linger "$USER" 2>/dev/null \
    || err "could not enable linger; run: sudo loginctl enable-linger $USER"
}

vram_ok() { # free VRAM per GPU >= VRAM[name], unless FORCE=1 (CUDA only)
  local name="$1" need="${VRAM[$name]}" line idx free bad=0
  [[ "${FORCE:-0}" == 1 ]] && { log "FORCE=1 — skipping VRAM check"; return 0; }
  if [[ "$ACCEL" != cuda ]]; then
    log "VRAM pre-check unavailable on accel=$ACCEL — starting without it"
    return 0
  fi
  command -v nvidia-smi >/dev/null || return 0
  while IFS=, read -r idx free; do
    free="${free// /}"; free="${free%MiB}"
    if (( free < need )); then
      err "GPU $idx has ${free} MiB free, '$name' needs ~${need} MiB per GPU"
      bad=1
    fi
  done < <(nvidia-smi --query-gpu=index,memory.free --format=csv,noheader,nounits 2>/dev/null | sed 's/, /,/')
  (( bad )) && { err "not enough VRAM — 'llmctl down <other>' first, or FORCE=1 to try anyway"; return 1; }
  return 0
}

gpu_report() {
  case "$ACCEL" in
    cuda)
      command -v nvidia-smi >/dev/null || return 0
      log "GPU memory:"
      nvidia-smi --query-gpu=index,memory.used,memory.total --format=csv,noheader | sed 's/^/    /';;
    rocm)
      command -v rocm-smi >/dev/null || return 0
      log "GPU memory (rocm):"
      rocm-smi --showmeminfo vram 2>/dev/null | grep -i vram | sed 's/^/    /' || true;;
    *) : ;;  # cpu — nothing to report
  esac
}

# ----------------------------------------------------------------------------
# Run scripts + units (generated fresh on every `up`/`set` — edit registry, not these)
# ----------------------------------------------------------------------------
write_external_run_script() { # generic template for models.d entries
  local name="$1" port="${PORT[$name]}" script="$RUN_DIR/run-$name.sh"
  local gpu_export="" accel_env="" gpu_flags="" mem_flag=""

  # never assume CUDA: device env var and GPU-only flags come from ACCEL
  [[ -n "$GPU_ENV_VAR" && -n "${GPUS[$name]}" ]] && gpu_export="export $GPU_ENV_VAR=${GPUS[$name]}"

  if [[ "${BACKEND[$name]}" == vllm ]]; then
    [[ "$ACCEL" == cuda ]] && accel_env="export VLLM_USE_FLASHINFER_SAMPLER=0"
    [[ "$ACCEL" != cpu ]] && mem_flag="--gpu-memory-utilization ${GUTIL[$name]} "
    cat > "$script" <<EOF
#!/usr/bin/env bash
# generated by llmctl from ${EXTERNAL[$name]} — edit that file, not this one
set -euo pipefail
export PATH="$(dirname "$VLLM_BIN"):\$PATH"
${gpu_export}
${accel_env}
export VLLM_NO_USAGE_STATS=1
exec "$VLLM_BIN" serve ${MREF[$name]} \\
  --served-model-name ${ID[$name]} \\
  --tensor-parallel-size ${TP[$name]} ${mem_flag}\\
  --max-model-len ${MAXLEN[$name]} \\
  --host 0.0.0.0 --port $port --api-key "\$(cat $VLLM_KEYFILE)" ${XARGS[$name]}
EOF
  else
    if [[ "$ACCEL" != cpu ]]; then
      gpu_flags="-ngl 99 "
      [[ "${GPUS[$name]}" == *,* ]] && gpu_flags+="--split-mode layer --tensor-split 1,1 "
    fi
    cat > "$script" <<EOF
#!/usr/bin/env bash
# generated by llmctl from ${EXTERNAL[$name]} — edit that file, not this one
set -euo pipefail
${gpu_export}
exec "$LLAMA_SERVER" -m "${MREF[$name]}" --alias ${ID[$name]} \\
  --host 0.0.0.0 --port $port ${gpu_flags}\\
  --ctx-size ${SRVCTX[$name]} -np ${STREAMS[$name]} --flash-attn on --jinja \\
  --api-key-file "$LLAMA_KEYFILE" ${XARGS[$name]}
EOF
  fi
  chmod +x "$script"
}

