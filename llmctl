# ----------------------------------------------------------------------------
# Reporting
# ----------------------------------------------------------------------------
print_table() {
  local i=1 name st
  printf '  %-2s %-14s %-9s %-6s %-11s %s\n' '#' name backend port status description
  for name in "${MODELS[@]}"; do
    st="$(status_of "$name")"
    printf '  %-2s %-14s %-9s %-6s %-11s %s\n' \
      "$i" "$name" "${BACKEND[$name]}" "${PORT[$name]}" "$st" "${DESC[$name]}"
    ((i++))
  done
}

agent_target() { # agent_target <agent> — "model @ url" as configured right now
  local a="$1" cfg="${A_CFG[$a]}" m="" u=""
  case "${A_TYPE[$a]}" in
    hermes)
      [[ -f "$cfg" ]] || { echo "(config missing: $cfg)"; return 0; }
      m="$(awk '/^model:/{f=1;next} f&&/^  default:/{print $2;exit}' "$cfg")"
      u="$(awk '/^model:/{f=1;next} f&&/^  base_url:/{print $2;exit}' "$cfg")"
      ;;
    openclaw)
      [[ -f "$cfg/openclaw.json" ]] || { echo "(config missing: $cfg/openclaw.json)"; return 0; }
      if command -v jq >/dev/null; then
        m="$(jq -r '.agents.defaults.model.primary // ""' "$cfg/openclaw.json")"
        u="$(jq -r '.models.providers.vllm.baseUrl // ""' "$cfg/openclaw.json")"
      fi
      ;;
  esac
  echo "${m:-?} @ ${u:-?}"
}

agents_report() {
  local a note
  ((${#AGENTS[@]})) || { echo "  (none registered — 'llmctl agent add' or $AGENTS_D/)"; return 0; }
  for a in "${AGENTS[@]}"; do
    note=""
    [[ "${A_FOLLOW[$a]}" == 1 ]] || note="  [pinned]"
    [[ -n "${A_FILE[$a]:-}" ]] || note+="  [legacy machine.conf keys]"
    printf '  %-12s %-10s -> %s%s\n' "$a" "(${A_TYPE[$a]})" "$(agent_target "$a")" "$note"
  done
}

cmd_agents() {
  if ((${#AGENTS[@]} == 0)); then
    log "no agents registered — 'llmctl agent add' writes $AGENTS_D/<name>.conf"
    return 0
  fi
  local a st legacy=0
  printf '  %-14s %-9s %-7s %-9s %s\n' name type follow gateway target
  for a in "${AGENTS[@]}"; do
    st="$(systemctl --user is-active "${A_UNIT[$a]}" 2>/dev/null || true)"
    printf '  %-14s %-9s %-7s %-9s %s\n' \
      "$a" "${A_TYPE[$a]}" "${A_FOLLOW[$a]}" "${st:-?}" "$(agent_target "$a")"
    [[ -n "${A_FILE[$a]:-}" ]] || legacy=1
  done
  echo
  if (( legacy )); then
    echo "  (synthesized from legacy machine.conf keys — 'llmctl agent add' or"
    echo "   'llmctl machine init' migrates them to $AGENTS_D/)"
  else
    echo "  (definitions: $AGENTS_D/<name>.conf — FOLLOW=1 agents move on every"
    echo "   'llmctl set'; pinned ones only via 'llmctl point <model> <name>')"
  fi
}

chat_report() { # browser links for whatever is up
  local name any=0
  for name in "${MODELS[@]}"; do
    is_active "$name" || continue
    (( any++ )) || echo "chat (browser):"
    if [[ "${BACKEND[$name]}" == llamacpp ]]; then
      echo "  $name -> $(chat_url "$name") (built into llama.cpp)"
    elif webui_running; then
      echo "  $name -> $(chat_url "$name") (open-webui, backend $(webui_base_url))"
    else
      echo "  $name -> open-webui is STOPPED — run: llmctl point $name"
    fi
  done
}

cmd_status() {
  echo "models:"
  print_table
  echo
  echo "agents:"
  agents_report
  echo
  chat_report
  echo
  gpu_report
  # flag any legacy unit still alive
  local u
  for u in "${LEGACY_UNITS[@]}"; do
    if systemctl --user is-active --quiet "$u" 2>/dev/null; then
      echo
      log "note: legacy unit $u is still running on :19434 — 'llmctl set <model>' will take over"
    fi
  done
  if [[ "$ACCEL" != cpu && ! -e "$SLEEP_HOOK" ]]; then
    echo
    log "note: no sleep hook — a suspend while a model is loaded wedges the GPU driver ('llmctl sleep-hook install')"
  fi
}

# ----------------------------------------------------------------------------
# Interactive menu
# ----------------------------------------------------------------------------
menu() {
  local ans n name
  while true; do
    echo
    print_table
    echo
    agents_report
    chat_report
    echo
    echo "  N = set model N (exclusive + point agents)   uN = up   dN = down   pN = point agents   a = add model   q = quit"
    read -rp "  > " ans || { echo; return 0; }
    case "$ans" in
      q|Q|'') return 0;;
      a|A) cmd_add;;
      [0-9]*)          n="$ans";          name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_set "$name"   || err "no model #$n";;
      u[0-9]*)         n="${ans#u}";      name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_up "$name"    || err "no model #$n";;
      d[0-9]*)         n="${ans#d}";      name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_down "$name"  || err "no model #$n";;
      p[0-9]*)         n="${ans#p}";      name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_point "$name" || err "no model #$n";;
      *) err "unrecognized: $ans";;
    esac
  done
}

# ----------------------------------------------------------------------------
usage() { awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"; }

case "${1:-menu}" in
  menu)          menu;;
  list)          print_table;;
  status)        cmd_status;;
  up)            shift; (($#)) || die "usage: llmctl up <model>..."; cmd_up "$@";;
  down)          shift; (($#)) || die "usage: llmctl down <model>...|all"; cmd_down "$@";;
  set)           shift; (($#==1)) || die "usage: llmctl set <model>"; cmd_set "$1";;
  point)         shift; (($#>=1)) || die "usage: llmctl point <model> [agent...]"; cmd_point "$@";;
  agents)        cmd_agents;;
  agent)         shift
                 case "${1:-}" in
                   add)    cmd_agent_add;;
                   remove) [[ -n "${2:-}" ]] || die "usage: llmctl agent remove <name>"; cmd_agent_remove "$2";;
                   *)      die "usage: llmctl agent add | llmctl agent remove <name>";;
                 esac;;
  env)           shift; (($#==1)) || die "usage: llmctl env <model>"; cmd_env "$1";;
  logs)          shift; (($#)) || die "usage: llmctl logs <model> [-f|N]"; cmd_logs "$@";;
  add)           cmd_add;;
  remove)        shift; (($#==1)) || die "usage: llmctl remove <model>"; cmd_remove "$1";;
  bench)         shift; (($#==1)) || die "usage: llmctl bench <model>"; cmd_bench "$1";;
  stats)         shift; cmd_stats "${1:-}";;
  machine)       shift; cmd_machine "${1:-show}";;
  sleep-hook)    shift; cmd_sleephook "${1:-status}";;
  sleep)         shift; cmd_sleep "${1:-}";;
  help|-h|--help) usage;;
  *)             # `llmctl <model-name>` == `llmctl set <model-name>`
                 if [[ -n "${PORT[${1}]:-}" ]]; then
                   cmd_set "$1"
                 else
                   die "unknown command or model '${1}' (models: ${MODELS[*]} — try: llmctl help)"
                 fi;;
esac
