check_prereqs() { # backend binaries / model files present
  local name="$1"
  [[ -s "${KEYFILE[$name]}" ]] || die "missing API key file ${KEYFILE[$name]}"
  case "${BACKEND[$name]}" in
    vllm)     [[ -x "$VLLM_BIN" ]] || die "vllm not found at $VLLM_BIN";;
    llamacpp) [[ -x "$LLAMA_SERVER" ]] || die "llama-server not found at $LLAMA_SERVER";;
  esac
  case "$name" in
    27b-q8)       [[ -f "$GGUF_27B" ]] || die "missing $GGUF_27B (hf download unsloth/Qwen3.6-27B-GGUF Qwen3.6-27B-Q8_0.gguf --local-dir $(dirname "$GGUF_27B"))";;
    35b-moe-gguf) [[ -f "$GGUF_35B" ]] || die "missing $GGUF_35B (hf download unsloth/Qwen3.6-35B-A3B-GGUF Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf --local-dir $(dirname "$GGUF_35B"))";;
  esac
  if [[ -n "${EXTERNAL[$name]:-}" && "${BACKEND[$name]}" == llamacpp && ! -f "${MREF[$name]}" ]]; then
    die "missing GGUF file ${MREF[$name]} (fix MODEL_REF in ${EXTERNAL[$name]} or download it)"
  fi
}

write_unit() { # write_unit <name>
  local name="$1" unit
  unit="$(unit_of "$name")"
  write_run_script "$name"
  mkdir -p "$SYSTEMD_USER_DIR"
  cat > "$SYSTEMD_USER_DIR/$unit" <<EOF
[Unit]
Description=llmctl: ${DESC[$name]} (:${PORT[$name]})
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=$RUN_DIR/run-$name.sh
Restart=always
RestartSec=10
TimeoutStopSec=60

[Install]
WantedBy=default.target
EOF
  systemctl --user daemon-reload
}

# ----------------------------------------------------------------------------
# Agent repointing
# ----------------------------------------------------------------------------
point_hermes() { # point_hermes <name>
  [[ "$HERMES_ENABLE" == 1 ]] || { log "hermes: disabled in machine profile — skipping"; return 0; }
  local name="$1" id="${ID[$name]}" url key bak
  url="$(url_of "$name")" key="$(key_of "$name")"
  [[ -f "$HERMES_CFG" ]] || { err "hermes config not found ($HERMES_CFG) — skipping"; return 0; }
  bak="$HERMES_CFG.bak.llmctl.$(date +%Y%m%d_%H%M%S)"
  cp "$HERMES_CFG" "$bak"

  # Edit only the top-level `model:` block (keeps comments/format elsewhere intact)
  awk -v id="$id" -v url="$url" -v key="$key" '
    /^model:/            { inblk=1; print; next }
    inblk && /^[^ ]/     { inblk=0 }
    inblk && /^  default:/  { print "  default: " id;  next }
    inblk && /^  base_url:/ { print "  base_url: " url; next }
    inblk && /^  api_key:/  { print "  api_key: " key;  next }
    { print }
  ' "$bak" > "$HERMES_CFG.tmp"

  # Validate the result parses and took the edit before installing it
  if python3 - "$HERMES_CFG.tmp" "$id" "$url" <<'PYEOF'
import sys, yaml
cfg = yaml.safe_load(open(sys.argv[1]))
m = cfg["model"]
assert m["default"] == sys.argv[2] and m["base_url"] == sys.argv[3], "model block not updated"
PYEOF
  then
    mv "$HERMES_CFG.tmp" "$HERMES_CFG"
    rm -f "$HERMES_CTX_CACHE"   # force re-probe of context length
    if systemctl --user is-active --quiet "$HERMES_UNIT" 2>/dev/null; then
      systemctl --user restart "$HERMES_UNIT"
      log "hermes -> $id @ $url (gateway restarted, backup: $(basename "$bak"))"
    else
      log "hermes -> $id @ $url (gateway not running; config updated, backup: $(basename "$bak"))"
    fi
  else
    rm -f "$HERMES_CFG.tmp"
    err "hermes config edit failed validation — original untouched (backup at $bak)"
    return 1
  fi
}

point_openclaw() { # point_openclaw <name>
  [[ "$OPENCLAW_ENABLE" == 1 ]] || { log "openclaw: disabled in machine profile — skipping"; return 0; }
  local name="$1" id="${ID[$name]}" url ctx key was_active=0
  url="$(url_of "$name")" ctx="${CTX[$name]}" key="$(key_of "$name")"
  [[ -f "$OPENCLAW_DIR/openclaw.json" ]] || { err "openclaw config not found — skipping"; return 0; }

  # openclaw rewrites its own config — stop the gateway before editing
  if systemctl --user is-active --quiet "$OPENCLAW_UNIT" 2>/dev/null; then
    was_active=1
    systemctl --user stop "$OPENCLAW_UNIT"
  fi

  OC_DIR="$OPENCLAW_DIR" OC_ID="$id" OC_URL="$url" OC_CTX="$ctx" OC_KEY="$key" python3 <<'PYEOF'
import json, os, shutil, time

d      = os.environ["OC_DIR"]
mid    = os.environ["OC_ID"]
url    = os.environ["OC_URL"]
ctx    = int(os.environ["OC_CTX"])
key    = os.environ["OC_KEY"]
stamp  = time.strftime("%Y%m%d_%H%M%S")

def edit(path, fn):
    if not os.path.exists(path):
        print(f"  [skip] {path} (not found)")
        return
    shutil.copy2(path, f"{path}.bak.llmctl.{stamp}")
    with open(path) as f:
        data = json.load(f)
    fn(data)
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")
    print(f"  [ok]   {path}")

def fix_provider(prov):
    prov["baseUrl"] = url
    for m in prov.get("models", [])[:1]:   # single local model per provider
        m["id"] = mid
        m["name"] = mid
        m["contextWindow"] = ctx

def main_cfg(data):
    fix_provider(data["models"]["providers"]["vllm"])
    data.setdefault("agents", {}).setdefault("defaults", {}) \
        .setdefault("model", {})["primary"] = f"vllm/{mid}"

def agent_models(data):
    fix_provider(data["providers"]["vllm"])

def auth(data):
    data["profiles"]["vllm:default"]["key"] = key

edit(os.path.join(d, "openclaw.json"), main_cfg)
edit(os.path.join(d, "agents/main/agent/models.json"), agent_models)
edit(os.path.join(d, "agents/main/agent/auth-profiles.json"), auth)
PYEOF
  local rc=$?

  if (( was_active )); then
    systemctl --user start "$OPENCLAW_UNIT"
  fi
  if (( rc == 0 )); then
    log "openclaw -> $id @ $url$( (( was_active )) && echo ' (gateway restarted)')"
  else
    err "openclaw config edit failed (backups: *.bak.llmctl.*) — check $OPENCLAW_DIR"
    return 1
  fi
}

# ----------------------------------------------------------------------------
# Browser chat (open-webui for vLLM, llama.cpp's built-in UI otherwise)
# ----------------------------------------------------------------------------
lan_ip() { hostname -I 2>/dev/null | awk '{print $1}'; }

chat_url() { # chat_url <name> — the page a human opens to talk to this model
  if [[ "${BACKEND[$1]}" == llamacpp ]]; then
    echo "http://localhost:${PORT[$1]}/"
  else
    echo "http://localhost:${WEBUI_PORT}/"
  fi
}

webui_running() {
  [[ "$(docker inspect -f '{{.State.Running}}' "$WEBUI_CONTAINER" 2>/dev/null)" == "true" ]]
}

webui_base_url() {
  docker inspect "$WEBUI_CONTAINER" --format '{{range .Config.Env}}{{println .}}{{end}}' 2>/dev/null \
    | sed -n 's/^OPENAI_API_BASE_URL=//p'
}

point_webui() { # point_webui <name> — vllm: run open-webui against it; llamacpp: stop it
  local name="$1"
  [[ "$WEBUI_ENABLE" == 1 ]] || return 0
  command -v docker >/dev/null 2>&1 || { err "docker not found — skipping web UI"; return 0; }

  if [[ "${BACKEND[$name]}" == llamacpp ]]; then
    if webui_running; then
      log "stopping ${WEBUI_CONTAINER} — llama.cpp serves its own chat UI at $(chat_url "$name")"
      docker stop "$WEBUI_CONTAINER" >/dev/null
    fi
    return 0
  fi

  local want="http://$(lan_ip):${PORT[$name]}/v1" have
  have="$(webui_base_url)"
  if [[ -n "$have" && "$have" == "$want" ]]; then
    if webui_running; then
      log "web UI: ${WEBUI_CONTAINER} already pointed at $want — $(chat_url "$name")"
    else
      docker start "$WEBUI_CONTAINER" >/dev/null
      log "web UI: started ${WEBUI_CONTAINER} — $(chat_url "$name")"
    fi
  else
    # endpoint changed: recreate the container (chats live in the docker volume
    # and survive; ENABLE_PERSISTENT_CONFIG=false makes the env authoritative)
    log "web UI: repointing ${WEBUI_CONTAINER} -> $want (recreating container, chats preserved)"
    docker rm -f "$WEBUI_CONTAINER" >/dev/null 2>&1 || true
    docker run -d --name "$WEBUI_CONTAINER" \
      -p "${WEBUI_PORT}:8080" \
      -v open-webui:/app/backend/data \
      --restart unless-stopped \
      -e OPENAI_API_BASE_URL="$want" \
      -e OPENAI_API_KEY="$(key_of "$name")" \
      -e ENABLE_PERSISTENT_CONFIG=false \
      -e WEBUI_AUTH=False \
      "$WEBUI_IMAGE" >/dev/null
    log "web UI: $(chat_url "$name")"
  fi
}

cmd_point() {
  local name="$1"; require_model "$name"
  is_healthy "$name" || err "warning: '$name' is not answering /health on :${PORT[$name]} — pointing agents anyway"
  point_hermes "$name"
  point_openclaw "$name"
  point_webui "$name"
  log "agents now target ${ID[$name]} @ $(url_of "$name") — chat in browser: $(chat_url "$name")"
}

# ----------------------------------------------------------------------------
# Lifecycle
# ----------------------------------------------------------------------------
cmd_up() { # start without stopping others
  local name
  for name in "$@"; do require_model "$name"; done
  ensure_linger
  # legacy units own :19434 — only displace them if a requested model needs it
  for name in "$@"; do
    [[ "${PORT[$name]}" == 19434 ]] && { stop_legacy; break; }
  done
  for name in "$@"; do
    if is_active "$name"; then log "'$name' already active on :${PORT[$name]}"; continue; fi
    check_prereqs "$name"
    vram_ok "$name" || return 1
    if start_model "$name"; then
      systemctl --user enable "$(unit_of "$name")" 2>/dev/null
      log "UP: $name — enabled on boot"
    else
      err "'$name' not healthy after ${TIMEOUT[$name]}s — stopping it. Logs: llmctl logs $name"
      systemctl --user stop "$(unit_of "$name")" || true
      return 1
    fi
  done
  gpu_report
}

cmd_down() {
  local names=("$@") name
  [[ "${1:-}" == all ]] && names=("${MODELS[@]}")
  for name in "${names[@]}"; do
    require_model "$name"
    systemctl --user stop "$(unit_of "$name")" 2>/dev/null || true
    systemctl --user disable "$(unit_of "$name")" 2>/dev/null || true
    log "DOWN: $name (stopped + removed from boot)"
  done
}

cmd_set() { # exclusive switch + agents; rolls back on failure
  local name="$1" prev=() m
  require_model "$name"
  check_prereqs "$name"
  for m in "${MODELS[@]}"; do
    [[ "$m" != "$name" ]] && is_active "$m" && prev+=("$m")
  done

  ensure_linger
  stop_legacy
  if ((${#prev[@]})); then
    log "stopping: ${prev[*]}"
    for m in "${prev[@]}"; do
      systemctl --user stop "$(unit_of "$m")" || true
      systemctl --user disable "$(unit_of "$m")" 2>/dev/null || true
    done
  fi

  if is_active "$name" && is_healthy "$name"; then
    log "'$name' already up on :${PORT[$name]}"
  else
    if ! start_model "$name"; then
      err "'$name' failed to become healthy in ${TIMEOUT[$name]}s. Logs: llmctl logs $name"
      systemctl --user stop "$(unit_of "$name")" || true
      if ((${#prev[@]})); then
        err "rolling back: restarting ${prev[*]} (agents left untouched)"
        for m in "${prev[@]}"; do
          systemctl --user start "$(unit_of "$m")" || true
          systemctl --user enable "$(unit_of "$m")" 2>/dev/null || true
        done
      fi
      return 1
    fi
  fi
  systemctl --user enable "$(unit_of "$name")" 2>/dev/null

  cmd_point "$name"
  gpu_report
  log "SET: $name is the active model — server + both agents survive reboot"
}

# ----------------------------------------------------------------------------
# Add / remove models (wizard writes ~/.config/llmctl/models.d/<name>.conf)
# ----------------------------------------------------------------------------
ask() { # ask <prompt> [default] — read with default
  local v
  read -rp "  $1${2:+ [$2]}: " v
  echo "${v:-${2:-}}"
}

next_free_port() {
  local p="$WIZARD_BASE_PORT" n used
  while :; do
    used=0
    for n in "${MODELS[@]}"; do [[ "${PORT[$n]}" == "$p" ]] && used=1; done
    ss -ltn 2>/dev/null | grep -q ":$p " && used=1
    (( used )) || { echo "$p"; return; }
    ((p++))
  done
}

cmd_add() {
  echo "llmctl add — register a new model (writes $MODELS_D/<name>.conf)"
  echo

  local name backend mref id port ctx gpus vram xargs desc timeout
  while :; do
    name="$(ask "short name (used in all llmctl commands)")"
    [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]] || { err "letters/digits/._- only"; continue; }
    [[ -n "${PORT[$name]:-}" ]] && { err "'$name' already exists"; continue; }
    break
  done

  local b
  b="$(ask "backend: 1=vllm (HF safetensors)  2=llama.cpp (GGUF)" 1)"
  [[ "$b" == 2 ]] && backend=llamacpp || backend=vllm

  if [[ "$backend" == vllm ]]; then
    mref="$(ask "HuggingFace repo (e.g. Qwen/Qwen3.6-27B-FP8)")"
    [[ -n "$mref" ]] || die "a model repo is required"
  else
    mref="$(ask "path to .gguf file")"
    mref="${mref/#\~/$HOME}"
    [[ -f "$mref" ]] || err "warning: $mref does not exist yet — download it before starting"
  fi

  id="$(ask "served model name (what agents/clients put in 'model')" "$name")"
  port="$(ask "port" "$(next_free_port)")"
  local n
  for n in "${MODELS[@]}"; do
    [[ "${PORT[$n]}" == "$port" ]] && die "port $port already used by '$n'"
  done
  ctx="$(ask "context window to advertise to agents (tokens)" 128000)"
  if [[ "$ACCEL" == cpu ]]; then
    gpus=""
  else
    gpus="$(ask "GPUs ($GPU_ENV_VAR)" "$GPUS_DEFAULT")"
  fi

  local tp gutil maxlen srvctx streams
  if [[ "$backend" == vllm ]]; then
    if [[ -n "$TENSOR_PARALLEL_DEFAULT" ]]; then tp="$TENSOR_PARALLEL_DEFAULT"
    elif [[ "$gpus" == *,* ]]; then tp=2; else tp=1; fi
    tp="$(ask "tensor-parallel-size" "$tp")"
    gutil="$(ask "gpu-memory-utilization (0.0-1.0)" 0.90)"
    maxlen="$(ask "max-model-len (server-side cap)" "$ctx")"
    timeout=900
  else
    srvctx="$(ask "server --ctx-size (total across streams)" "$ctx")"
    streams="$(ask "concurrent streams (-np)" 1)"
    timeout=300
  fi

  if [[ "$ACCEL" == cpu ]]; then
    vram=0
  else
    vram="$(ask "free VRAM needed per GPU before start, MiB (overestimate is safer)" 20000)"
  fi
  xargs="$(ask "extra server args (optional, appended verbatim)" "")"
  desc="$(ask "description" "$id ($backend)")"

  mkdir -p "$MODELS_D"
  local conf="$MODELS_D/$name.conf"
  {
    echo "# llmctl model definition — created $(date +%F) by 'llmctl add'"
    echo "# Edit freely; llmctl re-reads this on every run. Delete with: llmctl remove $name"
    echo "BACKEND=$backend"
    echo "PORT=$port"
    echo "MODEL_REF=\"$mref\""
    echo "MODEL_ID=\"$id\""
    echo "CTX=$ctx"
    echo "DESC=\"$desc\""
    echo "VRAM_MB=$vram"
    echo "HEALTH_TIMEOUT=$timeout"
    echo "GPUS=\"$gpus\""
    if [[ "$backend" == vllm ]]; then
      echo "TENSOR_PARALLEL=$tp"
      echo "GPU_UTIL=$gutil"
      echo "MAX_MODEL_LEN=$maxlen"
    else
      echo "SERVER_CTX=$srvctx"
      echo "STREAMS=$streams"
    fi
    [[ -n "$xargs" ]] && echo "EXTRA_ARGS=\"$xargs\""
  } > "$conf"

  log "registered '$name' -> $conf"
  echo
  local start
  start="$(ask "start it now with 'up' (runs alongside current models)? y/N" "n")"
  if [[ "$start" =~ ^[yY] ]]; then
    exec "$0" up "$name"   # re-exec so the new conf is loaded fresh
  else
    log "later: llmctl up $name   (or: llmctl set $name  to make it THE model + point agents)"
  fi
}

cmd_remove() {
  local name="$1"; require_model "$name"
  [[ -n "${EXTERNAL[$name]:-}" ]] || die "'$name' is a built-in (registry block in this script) — not removable here"
  local yn
  yn="$(ask "stop and unregister '$name' (${DESC[$name]})? y/N" "n")"
  [[ "$yn" =~ ^[yY] ]] || { log "aborted"; return 0; }
  systemctl --user stop "$(unit_of "$name")" 2>/dev/null || true
  systemctl --user disable "$(unit_of "$name")" 2>/dev/null || true
  rm -f "$SYSTEMD_USER_DIR/$(unit_of "$name")" "$RUN_DIR/run-$name.sh" "${EXTERNAL[$name]}"
  systemctl --user daemon-reload
  log "removed '$name' (conf, unit, run script). Model weights were NOT deleted."
}

# ----------------------------------------------------------------------------
# Machine profile: show effective values, or probe + generate machine.conf
# ----------------------------------------------------------------------------
machine_show() {
  if [[ -f "$MACHINE_CONF" ]]; then
    echo "profile: $MACHINE_CONF"
  else
    echo "profile: (none — using built-in defaults; 'llmctl machine init' to generate)"
  fi
  local k
  for k in MACHINE_NAME ACCEL GPUS_DEFAULT TENSOR_PARALLEL_DEFAULT VRAM_PER_GPU_MB \
           MODELS_DIR VLLM_BIN VLLM_KEYFILE LLAMA_SERVER LLAMA_KEYFILE \
           WIZARD_BASE_PORT ENABLE_BUILTIN_MODELS \
           HERMES_ENABLE HERMES_CFG OPENCLAW_ENABLE OPENCLAW_DIR \
           WEBUI_ENABLE WEBUI_CONTAINER WEBUI_PORT; do
    printf '  %-24s %s\n' "$k" "${!k:-—}"
  done
  printf '  %-24s %s\n' LEGACY_UNITS "${LEGACY_UNITS[*]:-—}"
  echo
  echo "probed hardware:"
  case "$ACCEL" in
    cuda) nvidia-smi --query-gpu=index,name,memory.total --format=csv,noheader 2>/dev/null | sed 's/^/  GPU /';;
    rocm) rocm-smi --showproductname 2>/dev/null | grep -i series | sed 's/^/  /' || echo "  (rocm-smi probe failed)";;
    *)    echo "  no GPU accelerator detected (accel=cpu)";;
  esac
  echo "  RAM: $(free -h 2>/dev/null | awk '/^Mem:/{print $2}')  CPUs: $(nproc 2>/dev/null)"
}

machine_init() {
  if [[ -f "$MACHINE_CONF" && "${FORCE:-0}" != 1 ]]; then
    die "$MACHINE_CONF already exists (FORCE=1 llmctl machine init to overwrite)"
  fi
  local mdir
  mdir="$(ask "where do model weights live on this machine" "$MODELS_DIR")"
  mdir="${mdir/#\~/$HOME}"
  [[ -d "$mdir" ]] || err "note: $mdir does not exist yet — create it before downloading models"
  MODELS_DIR="$mdir"
  local gpu_count=0 vram_min="" gpus="" tp=1
  if [[ "$ACCEL" == cuda ]]; then
    gpu_count="$(nvidia-smi -L 2>/dev/null | grep -c GPU || echo 0)"
    vram_min="$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | sort -n | head -1)"
  elif [[ "$ACCEL" == rocm ]]; then
    gpu_count="$(rocm-smi -i 2>/dev/null | grep -c '^GPU' || echo 0)"
  fi
  if (( gpu_count > 0 )); then
    gpus="$(seq -s, 0 $((gpu_count-1)))"
    tp="$gpu_count"
  fi
  mkdir -p "$(dirname "$MACHINE_CONF")"
  cat > "$MACHINE_CONF" <<EOF
# llmctl machine profile — generated $(date +%F) on $(hostname) by 'llmctl machine init'
# key=value; parsed (not sourced). Delete a line to fall back to llmctl's default.
MACHINE_NAME="$(hostname)"
ACCEL=$ACCEL
GPUS_DEFAULT="$gpus"
TENSOR_PARALLEL_DEFAULT=$tp
VRAM_PER_GPU_MB=${vram_min:-0}

# where model weights (gguf/) live — llmctl itself can be installed anywhere
MODELS_DIR="$MODELS_DIR"

# serving binaries + API key files (one key per backend)
VLLM_BIN="$VLLM_BIN"
VLLM_KEYFILE="$VLLM_KEYFILE"
LLAMA_SERVER="$LLAMA_SERVER"
LLAMA_KEYFILE="$LLAMA_KEYFILE"

# the built-in registry describes the dual-RTX-3090 box (DW-ASUS-LINUX);
# on other machines set 0 and define models with 'llmctl add' (models.d/)
ENABLE_BUILTIN_MODELS=$( [[ "$(hostname)" == "DW-ASUS-LINUX" ]] && echo 1 || echo 0 )
WIZARD_BASE_PORT=$WIZARD_BASE_PORT

# agents present on this machine (0 = llmctl won't touch them)
HERMES_ENABLE=$( [[ -f "$HERMES_CFG" ]] && echo 1 || echo 0 )
HERMES_CFG="$HERMES_CFG"
HERMES_UNIT="$HERMES_UNIT"
OPENCLAW_ENABLE=$( [[ -d "$OPENCLAW_DIR" ]] && echo 1 || echo 0 )
OPENCLAW_DIR="$OPENCLAW_DIR"
OPENCLAW_UNIT="$OPENCLAW_UNIT"

# browser chat for vLLM models (docker open-webui); llama.cpp uses its own UI
WEBUI_ENABLE=$( command -v docker >/dev/null 2>&1 && echo 1 || echo 0 )
WEBUI_CONTAINER="$WEBUI_CONTAINER"
WEBUI_PORT=$WEBUI_PORT
WEBUI_IMAGE="$WEBUI_IMAGE"

# old single-port units to stop/disable when llmctl takes over :19434
LEGACY_UNITS="${LEGACY_UNITS[*]}"
EOF
  log "wrote $MACHINE_CONF"
  log "review it, then: llmctl machine   (to see effective values)"
}

cmd_machine() {
  case "${1:-show}" in
    init)    machine_init;;
    show)    machine_show;;
    *)       die "usage: llmctl machine [init]";;
  esac
}

cmd_bench() {
  local name="$1"; require_model "$name"
  is_healthy "$name" || die "'$name' is not answering /health on :${PORT[$name]} — start it first"
  log "benchmarking ${ID[$name]} @ $(url_of "$name") (1 warmup + 200-token generation)…"
  bench_and_log "$name"
}

cmd_stats() {
  [[ -s "$STATS_FILE" ]] || die "no stats recorded yet ($STATS_FILE)"
  python3 - "$STATS_FILE" "${1:-}" <<'PYEOF'
import json, sys
from collections import defaultdict

path, only = sys.argv[1], sys.argv[2]
rows = []
with open(path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            r = json.loads(line)
        except ValueError:
            continue
        if only and r.get("model") != only:
            continue
        rows.append(r)

if not rows:
    print(f"no records{' for ' + only if only else ''}")
    sys.exit(0)

def fmt(v, suffix="", nd=1):
    return "-" if v is None else f"{round(v, nd):g}{suffix}"

print(f"{'when':<20}{'model':<15}{'load':>7}{'ttft':>7}{'pp t/s':>8}{'gen t/s':>8}  "
      f"{'gpu util / power (gen phase)'}")
for r in rows[-30:]:
    gs = [s for s in (r.get("gpu") or []) if s.get("phase", "gen") == "gen"]
    g = " ".join(f"GPU{s['gpu']}:{s['util_pct']:.0f}%/{s['power_w']:.0f}W" for s in gs)
    # pre-split records only have blended tok_s — show it in the gen column
    gen = r.get("gen_tps", r.get("tok_s"))
    print(f"{r.get('ts','?'):<20}{r.get('model','?'):<15}"
          f"{fmt(r.get('load_s'),'s',0):>7}{fmt(r.get('ttft_s'),'s',2):>7}"
          f"{fmt(r.get('prompt_tps')):>8}{fmt(gen):>8}  {g}")

agg = defaultdict(lambda: {"load": [], "pp": [], "gen": []})
for r in rows:
    a = agg[r.get("model", "?")]
    if r.get("load_s") is not None: a["load"].append(r["load_s"])
    if r.get("prompt_tps") is not None: a["pp"].append(r["prompt_tps"])
    gen = r.get("gen_tps", r.get("tok_s"))
    if gen is not None: a["gen"].append(gen)

def avg(xs): return sum(xs) / len(xs) if xs else None
print("\naverages:")
for m, a in sorted(agg.items()):
    print(f"  {m:<15} load {fmt(avg(a['load']),'s',0):>6} ({len(a['load'])} starts)   "
          f"prefill {fmt(avg(a['pp'])):>8} tok/s   gen {fmt(avg(a['gen'])):>6} tok/s "
          f"({len(a['gen'])} benches)")
PYEOF
}

cmd_logs() {
  local name="$1"; shift; require_model "$name"
  if [[ "${1:-}" == "-f" ]]; then
    journalctl --user -u "$(unit_of "$name")" -n 40 -f
  else
    journalctl --user -u "$(unit_of "$name")" -n "${1:-80}" --no-pager
  fi
}

cmd_env() {
  local name="$1"; require_model "$name"
  echo "export OPENAI_BASE_URL=$(url_of "$name")"
  echo "export OPENAI_API_KEY=$(key_of "$name")"
  echo "export OPENAI_MODEL=${ID[$name]}"
}

# ----------------------------------------------------------------------------
# Reporting
# ----------------------------------------------------------------------------
print_table() {
  local i=1 name st
  printf '  %-2s %-14s %-9s %-6s %-11s %s\n' '#' name backend port status description
  for name in "${MODELS[@]}"; do
    st="$(status_of "$name")"
    printf '  %-2s %-14s %-9s %-6s %-11s %s\n' \
      "$i" "$name" "${BACKEND[$name]}" "${PORT[$name]}" "$st" "${DESC[$name]}"
    ((i++))
  done
}

agents_report() {
  local h_model h_url oc_url oc_primary
  if [[ -f "$HERMES_CFG" ]]; then
    h_model="$(awk '/^model:/{f=1;next} f&&/^  default:/{print $2;exit}' "$HERMES_CFG")"
    h_url="$(awk '/^model:/{f=1;next} f&&/^  base_url:/{print $2;exit}' "$HERMES_CFG")"
    echo "  hermes   -> ${h_model:-?} @ ${h_url:-?}"
  fi
  if [[ -f "$OPENCLAW_DIR/openclaw.json" ]] && command -v jq >/dev/null; then
    oc_url="$(jq -r '.models.providers.vllm.baseUrl // "?"' "$OPENCLAW_DIR/openclaw.json")"
    oc_primary="$(jq -r '.agents.defaults.model.primary // "?"' "$OPENCLAW_DIR/openclaw.json")"
    echo "  openclaw -> ${oc_primary} @ ${oc_url}"
  fi
}

chat_report() { # browser links for whatever is up
  local name any=0
  for name in "${MODELS[@]}"; do
    is_active "$name" || continue
    (( any++ )) || echo "chat (browser):"
    if [[ "${BACKEND[$name]}" == llamacpp ]]; then
      echo "  $name -> $(chat_url "$name") (built into llama.cpp)"
    elif webui_running; then
      echo "  $name -> $(chat_url "$name") (open-webui, backend $(webui_base_url))"
    else
      echo "  $name -> open-webui is STOPPED — run: llmctl point $name"
    fi
  done
}

cmd_status() {
  echo "models:"
  print_table
  echo
  echo "agents:"
  agents_report
  echo
  chat_report
  echo
  gpu_report
  # flag any legacy unit still alive
  local u
  for u in "${LEGACY_UNITS[@]}"; do
    if systemctl --user is-active --quiet "$u" 2>/dev/null; then
      echo
      log "note: legacy unit $u is still running on :19434 — 'llmctl set <model>' will take over"
    fi
  done
}

# ----------------------------------------------------------------------------
# Interactive menu
# ----------------------------------------------------------------------------
menu() {
  local ans n name
  while true; do
    echo
    print_table
    echo
    agents_report
    chat_report
    echo
    echo "  N = set model N (exclusive + point agents)   uN = up   dN = down   pN = point agents   a = add model   q = quit"
    read -rp "  > " ans || { echo; return 0; }
    case "$ans" in
      q|Q|'') return 0;;
      a|A) cmd_add;;
      [0-9]*)          n="$ans";          name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_set "$name"   || err "no model #$n";;
      u[0-9]*)         n="${ans#u}";      name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_up "$name"    || err "no model #$n";;
      d[0-9]*)         n="${ans#d}";      name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_down "$name"  || err "no model #$n";;
      p[0-9]*)         n="${ans#p}";      name="${MODELS[$((n-1))]:-}"; [[ -n "$name" ]] && cmd_point "$name" || err "no model #$n";;
      *) err "unrecognized: $ans";;
    esac
  done
}

# ----------------------------------------------------------------------------
usage() { awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"; }

case "${1:-menu}" in
  menu)          menu;;
  list)          print_table;;
  status)        cmd_status;;
  up)            shift; (($#)) || die "usage: llmctl up <model>..."; cmd_up "$@";;
  down)          shift; (($#)) || die "usage: llmctl down <model>...|all"; cmd_down "$@";;
  set)           shift; (($#==1)) || die "usage: llmctl set <model>"; cmd_set "$1";;
  point)         shift; (($#==1)) || die "usage: llmctl point <model>"; cmd_point "$1";;
  env)           shift; (($#==1)) || die "usage: llmctl env <model>"; cmd_env "$1";;
  logs)          shift; (($#)) || die "usage: llmctl logs <model> [-f|N]"; cmd_logs "$@";;
  add)           cmd_add;;
  remove)        shift; (($#==1)) || die "usage: llmctl remove <model>"; cmd_remove "$1";;
  bench)         shift; (($#==1)) || die "usage: llmctl bench <model>"; cmd_bench "$1";;
  stats)         shift; cmd_stats "${1:-}";;
  machine)       shift; cmd_machine "${1:-show}";;
  help|-h|--help) usage;;
  *)             # `llmctl <model-name>` == `llmctl set <model-name>`
                 if [[ -n "${PORT[${1}]:-}" ]]; then
                   cmd_set "$1"
                 else
                   die "unknown command or model '${1}' (models: ${MODELS[*]} — try: llmctl help)"
                 fi;;
esac
